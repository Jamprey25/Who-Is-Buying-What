# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Anthropic — required for deal summary generation (dealSummaryPrompt.ts)
ANTHROPIC_API_KEY=

# Financial Modeling Prep — required for ticker search (tickerSearch.ts)
FMP_API_KEY=

# SEC EDGAR contact email — shown in User-Agent header sent to SEC.gov (secHttpClient.ts)
# Must be a valid email address. Defaults to sec-compliance@example.com if unset.
SEC_CONTACT_EMAIL=

# SerpAPI — optional, enables deal news search (secEdgarFeed.ts)
# Leave blank to disable news enrichment.
SERPAPI_KEY=
