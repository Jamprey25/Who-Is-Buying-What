# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Anthropic — required for deal summary generation (dealSummaryPrompt.ts)
ANTHROPIC_API_KEY=

# Financial Modeling Prep — required for ticker search (tickerSearch.ts)
FMP_API_KEY=

# SEC EDGAR contact email — shown in User-Agent header sent to SEC.gov (secHttpClient.ts)
# Must be a valid email address. Defaults to sec-compliance@example.com if unset.
SEC_CONTACT_EMAIL=

# SerpAPI — optional, enables deal news search (secEdgarFeed.ts)
# Leave blank to disable news enrichment.
SERPAPI_KEY=

# ─── LLM provider configuration ─────────────────────────────────────────────
# Default provider for all three LLM purposes (classify / extract / summary).
# Options: "anthropic" (pay-per-token, high quality)
#          "ollama"    (free, runs locally at http://localhost:11434)
LLM_PROVIDER=anthropic

# Per-purpose provider overrides. Leave blank to use LLM_PROVIDER.
# Example: use Ollama for classification (cheap) but Anthropic for extraction
# CLASSIFY_PROVIDER=ollama
# EXTRACT_PROVIDER=anthropic
# SUMMARY_PROVIDER=anthropic

# Enable disk cache for LLM responses (.cache/llm/). Set to 1 for dev to
# avoid re-paying for the same filing across test runs.
# LLM_CACHE=1

# Ollama-specific config.
# Install from ollama.com, then `ollama pull llama3.2:3b`.
# OLLAMA_MODEL=llama3.2:3b
# OLLAMA_BASE_URL=http://localhost:11434

# Anthropic model overrides — leave unset unless you want to pin specific
# model versions. Defaults use Haiku for all three (cheapest).
# ANTHROPIC_CLASSIFY_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_EXTRACT_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_SUMMARY_MODEL=claude-haiku-4-5-20251001
# Fallback Sonnet model used only when Haiku extraction fails Zod validation.
# ANTHROPIC_EXTRACT_FALLBACK_MODEL=claude-sonnet-4-6
